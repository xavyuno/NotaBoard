[node name="Title" type="LineEdit" parent="Boards/Settings/Note" unique_id=409101842]
layout_mode = 2
text = "Keybinds"
placeholder_text = "Title"

[node name="ScrollContainer" type="ScrollContainer" parent="Boards/Settings/Note" unique_id=1213997820]
layout_mode = 2
size_flags_vertical = 3
follow_focus = true

[node name="Notes" type="RichTextLabel" parent="Boards/Settings/Note/ScrollContainer" unique_id=114802699]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_styles/normal = SubResource("StyleBoxFlat_qt3dg")
theme_override_styles/focus = SubResource("StyleBoxFlat_qt3dg")
bbcode_enabled = true
text = "[b]Item keybinds:[/b][ul]
ctrl + z: Undo
ctrl + c: Copy (Pastes item at mouse position)
ctrl + x: Cut
ctrl + d: Duplicate (Pastes item in same position)
ctrl + r: Resets camera position
ctrl + s: Resize item
ctrl + g: Move item
delete: deletes selected item
ctrl + LMB: select multiple items at once
I [b]OR[/b] Scroll Up: Zoom in
O [b]OR[/b] Scroll Down: Zoom out
Note: Ctrl + Scrolling: Does not zoom in/out, this is to prevent scrolling in an item
[/ul]
[b]while editing a note:[/b][ul]
ctrl + b: bold text
[/ul]

And More to come."

[node name="Note2" type="VBoxContainer" parent="Boards/Settings" unique_id=2029623199]
clip_children = 2
